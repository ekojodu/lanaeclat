# =============================================
# LANA ECLAT BEAUTY STUDIO - Environment Variables
# Copy this file to .env and fill in your values
# NOTE: Vite requires the VITE_ prefix on all variables
# =============================================

# Business Info
VITE_BUSINESS_NAME="Lana Eclat Beauty Studio"
VITE_TAGLINE="Because glowing skin is not a luxury—it's a lifestyle."
VITE_LOCATION="Kabba, Kogi State, Nigeria"
VITE_PHONE="+234 000 000 0000"
VITE_EMAIL="hello@lanaeclat.com"
VITE_INSTAGRAM="@lanaeclat"
VITE_WHATSAPP="+234 000 000 0000"

# Reservation / Contact
VITE_RESERVATION_EMAIL="reservations@lanaeclat.com"
VITE_RESERVATION_SUBJECT="Appointment Request - Lana Eclat Beauty Studio"

# Google Maps
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY_HERE"
VITE_MAP_LAT="7.8256"
VITE_MAP_LNG="6.0656"
VITE_MAP_ZOOM="15"

# Social Links (optional)
VITE_FACEBOOK_URL=""
VITE_TIKTOK_URL=""
